# ================================================================
# GovBot KR 환경 설정
# 이 파일을 .env로 복사한 후 값을 수정하세요: cp .env.example .env
# ================================================================

# !! 보안 경고: SECRET_KEY를 반드시 변경하세요 !!
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
SECRET_KEY=change-this-in-production-32chars-or-longer

# JWT 토큰 만료 시간 (시간 단위)
JWT_EXPIRE_HOURS=24

# ── 데이터베이스
DATABASE_URL=postgresql+asyncpg://govbot:govbot@db:5432/govbot
REDIS_URL=redis://redis:6379

# ── 벡터DB
VECTOR_DB=chromadb
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── LLM Provider 설정
# 기본값: none (LLM 미사용 — Tier A/B만 동작)
LLM_PROVIDER=none

# LLM 활성화 예시 (주석 해제하여 사용):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── 임베딩 설정
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ── 개인정보 보관 기간 (일)
CHAT_LOG_RETENTION_DAYS=30

# ── Idempotency TTL (초)
IDEMPOTENCY_TTL_SECONDS=60

# ── 시스템 관리자 초기 계정
# 최초 실행 후 반드시 비밀번호를 변경하세요
ADMIN_DEFAULT_EMAIL=sysadmin@govbot.kr
ADMIN_DEFAULT_PASSWORD=changeme123!

# ── CORS 허용 오리진 (쉼표 구분)
ALLOWED_ORIGINS=["http://localhost","http://localhost:80"]
